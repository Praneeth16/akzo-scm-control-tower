# Copy to .env and fill in — used by run_local.sh for local dev against a real workspace.
DATABRICKS_CONFIG_PROFILE=DEFAULT

DATABRICKS_WAREHOUSE_ID=<warehouse-id>
AKZO_CATALOG=<catalog>
AKZO_SCHEMA=<schema>
DATABRICKS_CHAT_ENDPOINT=databricks-claude-opus-4-8

LAKEBASE_INSTANCE=<lakebase-instance>
LAKEBASE_DBNAME=databricks_postgres
LAKEBASE_SCHEMA=akzo
